# Kopiuj do .env.local i uzupełnij (NIE commituj .env.local).
# Bez żadnego klucza strona działa w trybie `mock` (canned, $0, bez 500).

AI_PROVIDER=mock                 # mock (domyślny, bez klucza) | anthropic | openai

ANTHROPIC_API_KEY=               # tylko serwer, BEZ prefiksu NEXT_PUBLIC_
OPENAI_API_KEY=                  # alternatywny dostawca

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- opcjonalny prod rate-limit (Upstash); aktywne gdy ustawione ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
